{
  "id": null,
  "uid": "mcpguard-main",
  "title": "MCPGuard \u2014 Security Dashboard",
  "tags": [
    "mcpguard",
    "mcp",
    "security"
  ],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Tool Calls / min",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 500
              },
              {
                "color": "red",
                "value": 1000
              }
            ]
          }
        }
      },
      "targets": [
        {
          "rawSql": "SELECT count() FROM mcpguard.tool_calls WHERE ts >= now() - INTERVAL 1 MINUTE",
          "format": "table"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Blocked (last 10 min)",
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "red"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        }
      },
      "targets": [
        {
          "rawSql": "SELECT count() FROM mcpguard.tool_calls WHERE verdict = 'block' AND ts >= now() - INTERVAL 10 MINUTE",
          "format": "table"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Avg Latency (ms)",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 100
              },
              {
                "color": "red",
                "value": 200
              }
            ]
          }
        }
      },
      "targets": [
        {
          "rawSql": "SELECT round(avg(latency_ms)) FROM mcpguard.tool_calls WHERE ts >= now() - INTERVAL 10 MINUTE",
          "format": "table"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Active Agents",
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          }
        }
      },
      "targets": [
        {
          "rawSql": "SELECT count(DISTINCT agent_id) FROM mcpguard.tool_calls WHERE ts >= now() - INTERVAL 30 MINUTE",
          "format": "table"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Tool Calls Over Time",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 16,
        "h": 8
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "allowed"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "green",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "blocked"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "review"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "orange",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "rawSql": "SELECT\n  toStartOfMinute(ts) AS time,\n  countIf(verdict = 'allow') AS allowed,\n  countIf(verdict = 'block') AS blocked,\n  countIf(verdict = 'review') AS review\nFROM mcpguard.tool_calls\nWHERE ts >= now() - INTERVAL 30 MINUTE\nGROUP BY time\nORDER BY time",
          "format": "table"
        }
      ]
    },
    {
      "id": 6,
      "type": "piechart",
      "title": "Verdicts Breakdown",
      "gridPos": {
        "x": 16,
        "y": 4,
        "w": 8,
        "h": 8
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "options": {
        "pieType": "donut",
        "legend": {
          "displayMode": "table",
          "placement": "right"
        }
      },
      "targets": [
        {
          "rawSql": "SELECT verdict, count() as count FROM mcpguard.tool_calls WHERE ts >= now() - INTERVAL 30 MINUTE GROUP BY verdict",
          "format": "table"
        }
      ]
    },
    {
      "id": 7,
      "type": "table",
      "title": "Recent Blocked Calls",
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "options": {
        "sortBy": [
          {
            "displayName": "ts",
            "desc": true
          }
        ]
      },
      "fieldConfig": {
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "verdict"
            },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "block": {
                        "color": "red",
                        "index": 0
                      },
                      "allow": {
                        "color": "green",
                        "index": 1
                      },
                      "review": {
                        "color": "yellow",
                        "index": 2
                      }
                    }
                  }
                ]
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "inject_score"
            },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "thresholds",
                "value": {
                  "steps": [
                    {
                      "color": "green",
                      "value": 0
                    },
                    {
                      "color": "yellow",
                      "value": 0.4
                    },
                    {
                      "color": "red",
                      "value": 0.8
                    }
                  ]
                }
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "rawSql": "SELECT ts, agent_id, tool, verdict, latency_ms, round(inject_score,2) as inject_score, block_reason FROM mcpguard.tool_calls WHERE verdict = 'block' AND ts >= now() - INTERVAL 30 MINUTE ORDER BY ts DESC LIMIT 50",
          "format": "table"
        }
      ]
    },
    {
      "id": 8,
      "type": "bargauge",
      "title": "Calls per Agent (30 min)",
      "gridPos": {
        "x": 0,
        "y": 20,
        "w": 12,
        "h": 7
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "continuous-BlYlRd"
          }
        }
      },
      "targets": [
        {
          "rawSql": "SELECT agent_id, count() as calls FROM mcpguard.tool_calls WHERE ts >= now() - INTERVAL 30 MINUTE GROUP BY agent_id ORDER BY calls DESC LIMIT 10",
          "format": "table"
        }
      ]
    },
    {
      "id": 9,
      "type": "bargauge",
      "title": "p99 Latency per Tool",
      "gridPos": {
        "x": 12,
        "y": 20,
        "w": 12,
        "h": 7
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": {
            "mode": "continuous-GrYlRd"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 100
              },
              {
                "color": "red",
                "value": 200
              }
            ]
          }
        }
      },
      "targets": [
        {
          "rawSql": "SELECT tool, quantile(0.99)(latency_ms) as p99 FROM mcpguard.tool_calls WHERE ts >= now() - INTERVAL 30 MINUTE GROUP BY tool ORDER BY p99 DESC",
          "format": "table"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Inject Score Over Time",
      "gridPos": {
        "x": 0,
        "y": 27,
        "w": 16,
        "h": 7
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 5
          },
          "min": 0,
          "max": 1
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "max_inject_score"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "avg_inject_score"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "orange",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "rawSql": "SELECT\n  toStartOfMinute(ts) AS time,\n  round(max(inject_score), 2) AS max_inject_score,\n  round(avg(inject_score), 2) AS avg_inject_score\nFROM mcpguard.tool_calls\nWHERE ts >= now() - INTERVAL 30 MINUTE\nGROUP BY time\nORDER BY time",
          "format": "table"
        }
      ]
    },
    {
      "id": 11,
      "type": "table",
      "title": "Block Reasons Summary",
      "gridPos": {
        "x": 16,
        "y": 27,
        "w": 8,
        "h": 7
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "targets": [
        {
          "rawSql": "SELECT block_reason, count() as count FROM mcpguard.tool_calls WHERE verdict = 'block' AND block_reason != '' AND ts >= now() - INTERVAL 30 MINUTE GROUP BY block_reason ORDER BY count DESC",
          "format": "table"
        }
      ]
    }
  ]
}