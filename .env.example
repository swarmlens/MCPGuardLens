# Your real MCP server URL
# For local dev: http://mcp-everything:3000 (default)
# For production: https://v1.yourdomain.com
UPSTREAM_MCP=http://mcp-everything:3000

# Gateway API key — agents must send: X-MCPGuard-Key: <value>
# Leave empty to disable auth (dev only)
# Generate: openssl rand -hex 32
GATEWAY_API_KEY=

# Rate limiting
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW=30

# Blocked payload patterns (comma-separated)
BLOCK_PATTERNS=rm -rf,DROP TABLE,/etc/passwd,/etc/shadow,../

LOG_LEVEL=info

# ── ClickHouse ───────────────────────────────────────────
CLICKHOUSE_USER=mcpguard
# Generate: openssl rand -hex 24
CLICKHOUSE_PASSWORD=mcpguard123
CLICKHOUSE_DB=mcpguard

# ── Grafana ──────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
# Generate: openssl rand -hex 16
GRAFANA_ADMIN_PASSWORD=mcpguard
# Your grafana subdomain (production only)
GRAFANA_DOMAIN=grafana.yourdomain.com

# ── GitHub MCP (optional, --profile github only) ─────────
GITHUB_PAT=ghp_your_token_here
